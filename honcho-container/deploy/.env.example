# Exact published image tag. Do not use :latest for a maintained installation.
HONCHO_IMAGE=ghcr.io/YOUR_GITHUB_USERNAME/honcho:main

# Synology persistent-data location.
DATA_ROOT=/volume2/docker/honcho

# API exposure. Use your NAS LAN IP instead of 0.0.0.0 to restrict binding.
HONCHO_BIND_ADDRESS=0.0.0.0
HONCHO_PORT=8000

# Pin infrastructure images before production use.
POSTGRES_IMAGE=pgvector/pgvector:pg15
REDIS_IMAGE=redis:8.2-alpine

POSTGRES_DB=honcho
POSTGRES_USER=honcho
POSTGRES_PASSWORD=REPLACE_WITH_A_LONG_RANDOM_PASSWORD

# Honcho configuration
AUTH_USE_AUTH=false
SENTRY_ENABLED=false
TELEMETRY_ENABLED=false
LOG_LEVEL=INFO

# Configure at least the providers required by your selected Honcho models.
# Leave unused keys empty.
LLM_GEMINI_API_KEY=
LLM_ANTHROPIC_API_KEY=
LLM_OPENAI_API_KEY=

# Optional advanced model overrides. Names may change between Honcho releases;
# copy supported variables from the matching upstream .env.template.
# DERIVER_MODEL_CONFIG__TRANSPORT=
# DERIVER_MODEL_CONFIG__MODEL=
# SUMMARY_MODEL_CONFIG__MODEL=
